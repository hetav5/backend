{
  "name": "xeno-backend",
  "version": "0.1.0",
  "description": "Xeno AI-native Mini CRM — backend (CRM API + stubbed channel service)",
  "private": true,
  "scripts": {
    "build": "nest build crm --webpack && nest build channel --webpack",
    "build:crm": "prisma generate && nest build crm --webpack",
    "build:channel": "nest build channel --webpack",
    "start:crm": "nest start crm",
    "start:crm:dev": "nest start crm --watch",
    "start:channel": "nest start channel",
    "start:channel:dev": "nest start channel --watch",
    "start:crm:prod": "prisma migrate deploy && node dist/apps/crm/main.js",
    "start:channel:prod": "node dist/apps/channel/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "jest",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.26",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "jest": "^30.4.2",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.4",
    "webpack": "^5.107.2",
    "webpack-node-externals": "^3.0.0"
  }
}
