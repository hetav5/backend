# --- Database & Redis ---
DATABASE_URL="postgresql://xeno:xeno@localhost:5432/xeno?schema=public"
REDIS_HOST="localhost"
REDIS_PORT=6379

# --- CRM API ---
CRM_PORT=3001
# Origin allowed by CORS (the Next.js frontend)
FRONTEND_ORIGIN="http://localhost:3000"

# --- Channel service ---
CHANNEL_PORT=3002
# Base URL the CRM uses to reach the channel service
CHANNEL_SERVICE_URL="http://localhost:3002"
# Base URL the channel service uses to call back into the CRM
CRM_BASE_URL="http://localhost:3001"

# Shared secret for HMAC-signing receipt callbacks (set to any random string; must match in both apps)
RECEIPT_HMAC_SECRET="change-me-to-a-long-random-string"

# Simulated channel behaviour
CHANNEL_FAILURE_RATE=0.08      # fraction of sends that hard-fail
CHANNEL_CONVERSION_RATE=0.15   # fraction of clicked comms that convert to an order

# --- LLM (Google Gemini, free AI Studio key) ---
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
